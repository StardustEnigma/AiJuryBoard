# SpacetimeDB Configuration
SPACETIME_URI=https://maincloud.spacetimedb.com
SPACETIME_DB=ai-jury-board

# AI Model APIs
CLAUDE_API_KEY=sk-...
GEMINI_API_KEY=...
TAVILY_API_KEY=...
LLAMA_API_KEY=...
ARMOR_IQ_KEY=...
ELEVENLABS_API_KEY=...
# Optional per-agent ElevenLabs voices
# If omitted, ELEVENLABS_VOICE_ID (or orchestrator default) is used.
ELEVENLABS_VOICE_ID_PROSECUTION=
ELEVENLABS_VOICE_ID_DEFENSE=
ELEVENLABS_VOICE_ID_DEVILS_ADVOCATE=

# Optional API endpoint overrides
# LLAMA_API_URL=https://api.groq.com/openai/v1/chat/completions
# LLAMA_API_KEY_HEADER=Authorization
# LLAMA_API_KEY_PREFIX=Bearer 
# ARMOR_IQ_VALIDATE_URL=https://api.armoriq.io/v1/validate
# ARMOR_IQ_BASE_URL=https://cloud-run-proxy.armoriq.io
# ARMOR_IQ_API_KEY_HEADER=Authorization
# ARMOR_IQ_API_KEY_PREFIX=Bearer 

# ArmorIQ token-flow settings (recommended for strict deployment)
# ARMOR_IQ_USE_TOKEN_FLOW=true
# ARMOR_IQ_TOKEN_ENDPOINT=https://cloud-run-proxy.armoriq.io/iap/process
# ARMOR_IQ_CLIENT_ID=...
# ARMOR_IQ_CLIENT_SECRET=...
# ARMOR_IQ_DOMAIN=...
# ARMOR_IQ_USER_ID=...
# ARMOR_IQ_AGENT_ID=...
# ARMOR_IQ_CONTEXT_ID=...
# ARMOR_IQ_ACCESS_TOKEN=...  # optional direct bearer token (if already issued)

# Optional strict mode toggles for infrastructure checks
# Set to true to fail hard instead of warning on network/TLS reachability issues.
ARMOR_IQ_REQUIRED=false
MONGODB_REQUIRED=false

# Optional local fallback engines (recommended for local development)
# If remote services are unstable/unreachable, these keep the app fully operational.
ARMOR_IQ_LOCAL_FALLBACK=true
MONGODB_LOCAL_FALLBACK=true

# MongoDB for Public Record
MONGODB_URI=mongodb+srv://...

# Node.js Environment
NODE_ENV=development
PORT=3001
